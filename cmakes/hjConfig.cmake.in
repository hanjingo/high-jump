    if(jwt-cpp_FOUND)
        list(APPEND hj_LIBRARIES jwt-cpp::jwt-cpp)
    endif()
endif()

# Remove duplicates
list(REMOVE_DUPLICATES hj_LIBRARIES)

# Export the libraries variable
set(hj_LIBRARIES ${hj_LIBRARIES} CACHE INTERNAL "High-jump libraries")