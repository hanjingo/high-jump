@PACKAGE_INIT@
include("${CMAKE_CURRENT_LIST_DIR}/hjTargets.cmake")
set(hj_INCLUDE_DIR "@PACKAGE_CMAKE_INSTALL_FULL_INCLUDEDIR@")
check_required_components(hj)

# ==============================================================================
# Auto find high-jump dependencies and set hj_LIBRARIES
# ==============================================================================

set(hj_LIBRARIES "")

# Helper macro to find package and append to hj_LIBRARIES
macro(hj_find_and_append pkg_name)
    find_package(${pkg_name} CONFIG QUIET)
    if(${pkg_name}_FOUND OR ${ARGV1})
        list(APPEND hj_LIBRARIES ${ARGN})
    endif()
endmacro()

# Core dependencies (always required)
find_package(Boost REQUIRED COMPONENTS 
    filesystem 
    stacktrace_basic
)
list(APPEND hj_LIBRARIES ${Boost_LIBRARIES})

find_package(fmt CONFIG QUIET)
if(fmt_FOUND)
    list(APPEND hj_LIBRARIES fmt::fmt)
endif()

find_package(nlohmann_json CONFIG QUIET)
if(nlohmann_json_FOUND)
    list(APPEND hj_LIBRARIES nlohmann_json::nlohmann_json)
endif()

find_package(absl CONFIG QUIET)
if(absl_FOUND)
    list(APPEND hj_LIBRARIES 
        absl::base
        absl::strings
        absl::synchronization
    )
endif()

# concurrentqueue is header-only, no link target needed

# ==============================================================================
# Feature-based dependencies (conditionally found based on vcpkg features)
# ==============================================================================

# AI module
if(@HJ_ENABLE_AI@)
    find_path(QRENCODE_INCLUDE_DIR NAMES qrencode.h)
    find_library(QRENCODE_LIBRARY qrencode)
    if(QRENCODE_LIBRARY)
        list(APPEND hj_LIBRARIES ${QRENCODE_LIBRARY})
    endif()
    
    find_package(quirc CONFIG QUIET)
    if(quirc_FOUND)
        list(APPEND hj_LIBRARIES quirc::quirc)
    endif()
endif()

# Algo module
if(@HJ_ENABLE_ALGO@)
    find_package(Boost QUIET COMPONENTS algorithm)
    find_package(behaviortree_cpp CONFIG QUIET)
    if(behaviortree_cpp_FOUND)
        list(APPEND hj_LIBRARIES BT::behaviortree_cpp)
    endif()
endif()

# Compress module
if(@HJ_ENABLE_COMPRESS@)
    find_package(ZLIB QUIET)
    if(ZLIB_FOUND)
        list(APPEND hj_LIBRARIES ZLIB::ZLIB)
    endif()
    
    find_package(zstd CONFIG QUIET)
    if(zstd_FOUND)
        list(APPEND hj_LIBRARIES zstd::libzstd)
    endif()
endif()

# Crypto module
if(@HJ_ENABLE_CRYPTO@)
    find_package(OpenSSL QUIET)
    if(OpenSSL_FOUND)
        list(APPEND hj_LIBRARIES OpenSSL::SSL OpenSSL::Crypto)
    endif()
endif()

