        list(APPEND hj_LIBRARIES hiredis::hiredis)
    endif()
    
    find_package(clickhouse-cpp CONFIG QUIET)
    if(TARGET clickhouse-cpp-lib)
        list(APPEND hj_LIBRARIES clickhouse-cpp-lib::clickhouse-cpp-lib)
    endif()
    
    find_package(libpqxx CONFIG QUIET)
    if(libpqxx_FOUND)
        list(APPEND hj_LIBRARIES libpqxx::pqxx)
    endif()
endif()

