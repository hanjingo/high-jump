PACKAGE_NAME=lic
PACKAGE_VERSION_MAJOR=0
PACKAGE_VERSION_MINOR=0
PACKAGE_VERSION_PATCH=1
PACKAGE_BUGREPORT=https://github.com/hanjingo/high-jump/issues
PACKAGE_CONTACT=hehehunanchina@live.com
PACKAGE_VENDOR=hanjingo
PACKAGE_RESOURCE_FILE_LICENSE=LICENSE
PACKAGE_DESCRIPTION_SUMMARY=The lic project

# license
LIC_ENABLE=0
LIC_ISSUER=hehehunanchina@live.com
LIC_FPATH=./license.lic

# crash trace
CRASH_HANDLER_ENABLE=1

# telemetry
TELEMETRY_ENABLE=1

# property
PROPERTY_ENABLE=1

# for library-core
LIC_CORE_VERSION_MAJOR_MIN=0
LIC_CORE_VERSION_MINOR_MIN=0
LIC_CORE_VERSION_PATCH_MIN=1